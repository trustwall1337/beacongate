<?xml version="1.0" encoding="utf-8"?>
<!--
  Single-screen UI for v1. Three logical sections, gated by the
  ConnectionState:

    - importGroup    : visible in Empty / ImportFailed states
    - statusGroup    : visible in Idle / VpnConsent / Connecting / Connected / Failed
    - errorBanner    : visible in ImportFailed / Failed states

  XML + Views (not Compose) for APK size — saves ~3 MB after R8.
  Material3 styling comes from the shared Theme.BeaconGate.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textStyle="bold"
            android:text="@string/app_name" />

        <TextView
            android:id="@+id/versionLine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="Version 0.1.0" />

        <!-- ===== Status section (visible once a config is imported) ===== -->
        <LinearLayout
            android:id="@+id/statusGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/statusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:text="@string/status_label" />

            <TextView
                android:id="@+id/statusValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="Connected" />

            <TextView
                android:id="@+id/friendLine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="14sp"
                tools:text="Imported: mahdi" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/primaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:textSize="16sp"
                tools:text="Connect" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/reimportButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="14sp"
                android:text="@string/reimport_button" />
        </LinearLayout>

        <!-- ===== Import section (visible when no config is stored) ===== -->
        <LinearLayout
            android:id="@+id/importGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            tools:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:text="@string/import_section_title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:text="@string/import_treat_as_password" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/driveLinkLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/drive_link_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/driveLinkInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:maxLines="3" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/fetchDriveButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/fetch_drive_button" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:text="@string/or_pick_file" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pickFileButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/pick_file_button" />
        </LinearLayout>

        <!-- ===== Error banner (Importing failure or Connect failure) ==== -->
        <LinearLayout
            android:id="@+id/errorBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:padding="16dp"
            android:background="?attr/colorErrorContainer"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="@string/error_banner_title" />

            <TextView
                android:id="@+id/errorMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="13sp"
                tools:text="Drive returned an HTML page instead of the config." />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dismissErrorButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_gravity="end"
                android:text="@string/dismiss_button" />
        </LinearLayout>

        <!-- Filler so the layout doesn't pile at the top on tall screens. -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

    </LinearLayout>
</ScrollView>
